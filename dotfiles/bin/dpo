#!/bin/bash

re="^[0-9]+$"
if ! [[ $1 =~ $re ]] ; then
   echo "error: invalid pre number" >&2; exit 1
fi

msg=`git log --pretty=oneline -n 1|gsed 's/^[0-9a-z]*\s//g'`
echo $2

git add -u
if [ -z "$2" ];then
  if [ "$msg" = "debug" ];then
    git ci --amend --no-edit
  else
    git ci -m "debug"
  fi
else
  git ci -m "$2"
fi
git push origin head -f
dae pre update --pre $1
