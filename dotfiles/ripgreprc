# Don't let ripgrep vomit really long lines to my terminal, and show a preview.
--max-columns=150
--max-columns-preview

# Add my 'web' type.
--type-add
web:*.{html,css,js}*

# Using glob patterns to include/exclude files or folders
--glob=!node_modules/*
--glob=!git/*
--glob=!tags
--glob=!venv/*
--glob=!.venv/*
--glob=!.env/*
--glob=!env/*

# Because who cares about case!?
--smart-case
