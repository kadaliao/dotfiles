{{- $frp := include "frp/encrypted_private_machines.toml.asc" | decrypt | fromToml -}}
{{- $machineID := index . "frp_machine" | default "" -}}
{{- if not $machineID -}}
{{- fail "No frp_machine configured. Set frp_machine in ~/.config/chezmoi/chezmoi.toml [data] to one of frp/machines.toml machines." -}}
{{- end -}}
{{- $machine := index $frp.machines $machineID -}}
{{- if not $machine -}}
{{- fail (printf "No FRP machine config for frp_machine %q. Add [machines.%s] to the encrypted FRP machine inventory." $machineID $machineID) -}}
{{- end -}}
{{- $defaults := index $frp "defaults" -}}
{{- $label := index $machine "label" -}}
{{- $listeners := $machine.listeners -}}
{{- $endpoint := index $machine.endpoints "tx" -}}
{{- $secrets := index . "frp_secrets" | default dict -}}
{{- $secretMachines := index $secrets "machines" | default dict -}}
{{- $machineSecrets := index $secretMachines $machineID | default dict -}}
{{- $secretEndpoints := index $machineSecrets "endpoints" | default dict -}}
{{- $endpointSecrets := index $secretEndpoints "tx" | default dict -}}
{{- $httpProxyUsername := index $endpointSecrets "http_proxy_username" | default "" -}}
{{- $httpProxyPassword := index $endpointSecrets "http_proxy_password" | default "" -}}
# frp client config generated by chezmoi for frp_machine={{ $machineID }} ({{ $label }})
# Endpoint: tx

serverAddr = "{{ $endpoint.server_addr }}"
serverPort = {{ $endpoint.server_port }}
transport.poolCount = {{ $endpoint.pool_count }}

# SSH - local {{ $listeners.ssh_port }} -> tx remote {{ $endpoint.ssh_remote_port }}
[[proxies]]
name = "tx-{{ $label }}-ssh-{{ $endpoint.ssh_remote_port }}"
type = "tcp"
localIP = "127.0.0.1"
localPort = {{ $listeners.ssh_port }}
remotePort = {{ $endpoint.ssh_remote_port }}

{{- if and $httpProxyUsername $httpProxyPassword }}
# Authenticated HTTP proxy handled by frpc.
[[proxies]]
name = "tx-{{ $label }}-http-proxy-{{ $endpoint.clash_remote_port }}"
type = "tcp"
remotePort = {{ $endpoint.clash_remote_port }}

[proxies.plugin]
type = "http_proxy"
httpUser = "{{ $httpProxyUsername }}"
httpPassword = "{{ $httpProxyPassword }}"
{{- else }}
# Clash/Mihomo authenticated mixed listener.
[[proxies]]
name = "tx-{{ $label }}-clash-auth-{{ $endpoint.clash_remote_port }}"
type = "tcp"
localIP = "127.0.0.1"
localPort = {{ $listeners.clash_auth_port }}
remotePort = {{ $endpoint.clash_remote_port }}
{{- end }}
{{- if and (hasKey $listeners "multica_port") (hasKey $endpoint "multica_domains") }}

# Multica self-host single-domain entrypoint.
[[proxies]]
name = "tx-{{ $label }}-multica-{{ $listeners.multica_port }}"
type = "http"
localIP = "127.0.0.1"
localPort = {{ $listeners.multica_port }}
customDomains = [
{{- range $domain := $endpoint.multica_domains }}
    "{{ $domain }}",
{{- end }}
]
{{- end }}

# Local web service.
[[proxies]]
name = "tx-{{ $label }}-web-{{ $listeners.web_port }}"
type = "http"
localIP = "127.0.0.1"
localPort = {{ $listeners.web_port }}
customDomains = [
{{- range $domain := $endpoint.web_domains }}
    "{{ $domain }}",
{{- end }}
]
{{- if and (hasKey $listeners "web2_port") (hasKey $endpoint "web2_domains") }}

# Local web2 service.
[[proxies]]
name = "tx-{{ $label }}-web2-{{ $listeners.web2_port }}"
type = "http"
localIP = "127.0.0.1"
localPort = {{ $listeners.web2_port }}
customDomains = [
{{- range $domain := $endpoint.web2_domains }}
    "{{ $domain }}",
{{- end }}
]
{{- end }}
