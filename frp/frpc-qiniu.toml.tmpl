{{- $frp := include "frp/encrypted_machines.toml.asc" | decrypt | fromToml -}}
{{- $machine := index $frp.machines .chezmoi.hostname -}}
{{- if not $machine -}}
{{- fail (printf "No FRP machine config for hostname %s. Add it to the encrypted FRP machine inventory" .chezmoi.hostname) -}}
{{- end -}}
{{- $label := index $machine "label" -}}
{{- $listeners := $machine.listeners -}}
{{- $endpoint := index $machine.endpoints "qiniu" -}}
{{- $secrets := index . "frp_secrets" | default dict -}}
{{- $secretMachines := index $secrets "machines" | default dict -}}
{{- $machineSecrets := index $secretMachines .chezmoi.hostname | default dict -}}
{{- $secretEndpoints := index $machineSecrets "endpoints" | default dict -}}
{{- $endpointSecrets := index $secretEndpoints "qiniu" | default dict -}}
# frp client config generated by chezmoi for {{ .chezmoi.hostname }} ({{ $label }})
# Endpoint: qiniu

serverAddr = "{{ $endpoint.server_addr }}"
serverPort = {{ $endpoint.server_port }}
transport.poolCount = {{ $endpoint.pool_count }}
{{- if and $endpointSecrets $endpointSecrets.auth_token }}

auth.token = "{{ $endpointSecrets.auth_token }}"
{{- end }}

# SSH - local {{ $listeners.ssh_port }} -> qiniu remote {{ $endpoint.ssh_remote_port }}
[[proxies]]
name = "qiniu-{{ $label }}-ssh-{{ $endpoint.ssh_remote_port }}"
type = "tcp"
localIP = "127.0.0.1"
localPort = {{ $listeners.ssh_port }}
remotePort = {{ $endpoint.ssh_remote_port }}

# Clash/Mihomo authenticated mixed listener.
[[proxies]]
name = "qiniu-{{ $label }}-clash-auth-{{ $endpoint.clash_remote_port }}"
type = "tcp"
localIP = "127.0.0.1"
localPort = {{ $listeners.clash_auth_port }}
remotePort = {{ $endpoint.clash_remote_port }}

# Local web service.
[[proxies]]
name = "qiniu-{{ $label }}-web-{{ $listeners.web_port }}"
type = "http"
localIP = "127.0.0.1"
localPort = {{ $listeners.web_port }}
customDomains = [
{{- range $domain := $endpoint.web_domains }}
    "{{ $domain }}",
{{- end }}
]
